{
  "name": "Python Notebook Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "pip install -r .devcontainer/requirements.txt",
  "forwardPorts": [5000, 8000, 11888],
  "remoteUser": "root"
}